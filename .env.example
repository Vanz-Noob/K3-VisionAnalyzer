# Endpoint backend untuk meminta pre-signed PUT URL ke BytePlus TOS
VITE_TOS_PRESIGN_ENDPOINT=/api/tos/presigned-url

# Endpoint backend untuk meneruskan request analisis gambar ke LLM
VITE_LLM_ANALYZE_ENDPOINT=/api/llm/analyze

# Catatan:
# - JANGAN simpan TOS Access Key / Secret Key di frontend.
# - Backend Anda yang menandatangani request ke TOS dan memanggil LLM provider.
# - Bucket name & region dikonfigurasi di backend, bukan di .env frontend.
